# Environment variables / secrets
.env

# Python virtual environments
venv/
.venv/

# Python bytecode / caches
__pycache__/
*.pyc

# Local data files (keep the folder, ignore its contents)
data/*
!data/.gitkeep

# DuckDB / local database files
*.duckdb
*.db

# dbt artifacts
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Task spec files (local instructions, not part of the project)
pipeline_stage*_task.md
